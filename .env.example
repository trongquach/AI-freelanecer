# ─── Database ─────────────────────────────────────
MYSQL_ROOT_PASSWORD=StrongPassword@2024
MYSQL_DATABASE=aimarket_db

# ─── Redis ────────────────────────────────────────
REDIS_PASSWORD=

# ─── JWT (RS256 - generate with: openssl genrsa -out private.pem 2048) ──
JWT_PRIVATE_KEY_BASE64=YOUR_BASE64_ENCODED_RSA_PRIVATE_KEY
JWT_PUBLIC_KEY_BASE64=YOUR_BASE64_ENCODED_RSA_PUBLIC_KEY

# ─── AI APIs ──────────────────────────────────────
AI_PROVIDER=openAi

OPENAI_API_KEY=sk-YOUR_OPENAI_KEY

# ─── Stripe ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ─── AWS ──────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
S3_BUCKET_NAME=aimarket-uploads-dev

# ─── Frontend ─────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (Optional for dev - logs to console) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ─── Production DB (prod profile only) ───────────
DB_URL=jdbc:mysql://your-rds-endpoint:3306/aimarket_db
DB_USERNAME=admin
DB_PASSWORD=your-rds-password
REDIS_HOST=your-elasticache-endpoint
REDIS_PORT=63798
